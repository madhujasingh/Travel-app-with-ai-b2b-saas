# Backend Environment Variables
# Copy this file to .env and fill in the values

# Server Configuration
SERVER_PORT=8080

# Database Configuration
DATABASE_URL=jdbc:postgresql://localhost:5432/itinera_db
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_secure_password_here

# JPA Configuration
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# JWT Configuration
JWT_SECRET=your_very_long_and_secure_jwt_secret_key_here_at_least_256_bits
JWT_EXPIRATION=86400000
GOOGLE_WEB_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com
AUTH_MAX_ADMIN_COUNT=2
AUTHORIZED_ADMIN_EMAILS=admin@itinera.com

# Email Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:19006,http://localhost:8081,exp://localhost:19000

# Logging Configuration
LOG_LEVEL=INFO
LOG_LEVEL_WEB=INFO

# Frontend Environment Variables
# Create a .env file in the root directory with these variables

REACT_APP_API_URL=http://localhost:8080/api
REACT_APP_AI_SERVICE_URL=http://localhost:8000
REACT_APP_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com
REACT_APP_GOOGLE_IOS_CLIENT_ID=
REACT_APP_GOOGLE_ANDROID_CLIENT_ID=
