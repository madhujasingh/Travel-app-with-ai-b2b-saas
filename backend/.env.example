# Backend runtime config
SERVER_PORT=8080
DATABASE_URL=jdbc:postgresql://localhost:5432/itinera_db
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRATION=86400000
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
AUTH_MAX_ADMIN_COUNT=2
AUTHORIZED_ADMIN_EMAILS=admin@itinera.com
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
CORS_ALLOWED_ORIGINS=http://localhost:19006,http://localhost:8081,exp://localhost:19000
LOG_LEVEL=INFO
LOG_LEVEL_WEB=INFO
